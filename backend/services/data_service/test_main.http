### Health check
GET http://127.0.0.1:8001/health

### Import test cases for project 1
POST http://127.0.0.1:8001/api/v1/projects/1/test-cases/import
Content-Type: application/json

{
  "items": [
    {
      "external_id": "AUTH-001",
      "title": "Успешный вход по email и паролю",
      "preconditions": "Пользователь существует в системе",
      "steps": "1. Открыть экран логина
2. Ввести email
3. Ввести пароль
4. Нажать кнопку Войти",
      "expected_result": "Пользователь успешно авторизован и попадает на главный экран",
      "tags": ["auth", "login", "smoke"],
      "priority": "high"
    },
    {
      "external_id": "AUTH-002",
      "title": "Ошибка при вводе невалидного email",
      "preconditions": "Открыт экран логина",
      "steps": "1. Ввести некорректный email
2. Заполнить пароль
3. Нажать кнопку Войти",
      "expected_result": "Отображается ошибка валидации email, запрос на сервер не отправляется",
      "tags": ["auth", "login", "validation"],
      "priority": "high"
    },
    {
      "external_id": "AUTH-003",
      "title": "Ошибка 401 при неверном пароле",
      "preconditions": "Пользователь существует в системе",
      "steps": "1. Открыть экран логина
2. Ввести корректный email
3. Ввести неверный пароль
4. Нажать кнопку Войти",
      "expected_result": "Отображается сообщение о неверных учетных данных",
      "tags": ["auth", "login", "error-handling"],
      "priority": "medium"
    }
  ]
}

### Get all test cases for project 1
GET http://127.0.0.1:8001/api/v1/projects/1/test-cases

### Get one test case by id
GET http://127.0.0.1:8001/api/v1/test-cases/1

### Search test cases by change summary
POST http://127.0.0.1:8001/api/v1/projects/1/test-cases/search
Content-Type: application/json

{
  "query": "Изменен экран логина, добавлена валидация email и обработка ошибки 401",
  "limit": 10
}
